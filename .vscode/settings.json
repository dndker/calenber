{
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "[javascript]": {
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "[typescript]": {
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "[typescriptreact]": {
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    "htmltagwrap.tag": "div",
    "htmltagwrap.autoDeselectClosingTag": true,
    "errorLens.codeLensEnabled": false,
    "editor.tabSize": 4,
    "prettier.tabWidth": 4,
    "files.watcherExclude": {
        "**/.next/**": true,
        "**/node_modules/**": true,
        "**/.source/**": true,
        "**/dist/**": true
    },
    "files.exclude": {
        "**/.next": true,
        "**/.source": true
    },
    "tailwindCSS.experimental.configFile": "packages/ui/src/styles/globals.css",
    "tailwindCSS.includeLanguages": {
        "typescriptreact": "typescriptreact",
        "javascriptreact": "javascriptreact"
    },
    "css.lint.unknownAtRules": "ignore",
    "scss.lint.unknownAtRules": "ignore",
    "less.lint.unknownAtRules": "ignore",
    "editor.quickSuggestions": {
        "strings": true
    },
    "editor.fontFamily": "D2Coding, Menlo, Monaco, 'Courier New', monospace, MesloLGS NF",
    "terminal.integrated.fontFamily": "D2Coding, Menlo, Monaco, monospace, MesloLGS NF",
    "files.eol": "\n",
    "files.associations": {
        "*.sql": "postgresql"
    }
}
